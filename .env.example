NS_APP_NAME=NOVA-SYNESIS
NS_ENVIRONMENT=production
NS_LOG_LEVEL=INFO
NS_DATABASE_PATH=data/orchestrator.db
NS_WORKING_DIRECTORY=.
NS_API_HOST=127.0.0.1
NS_API_PORT=8000
NS_SHORT_TERM_BACKEND=memory
NS_LONG_TERM_BACKEND=data/long_term_memory.db
NS_VECTOR_BACKEND=data/vector_memory.db
NS_MAX_FLOW_CONCURRENCY=4
NS_LIT_BINARY_PATH=LIT/lit.windows_x86_64.exe
NS_LIT_MODEL_PATH=LIT/gemma-4-E2B-it.litertlm
NS_LIT_BACKEND=cpu
NS_LIT_TIMEOUT_S=240
NS_SECURITY_ENABLED=true
NS_SECURITY_HTTP_ALLOWED_HOSTS=127.0.0.1,localhost
NS_SECURITY_SEND_PROTOCOLS=MESSAGE_QUEUE
NS_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

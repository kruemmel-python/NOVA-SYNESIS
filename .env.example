NS_APP_NAME=NOVA-SYNESIS
NS_ENVIRONMENT=production
NS_LOG_LEVEL=INFO
NS_DATABASE_PATH=data/orchestrator.db
NS_WORKING_DIRECTORY=.
NS_API_HOST=127.0.0.1
NS_API_PORT=8000
NS_SHORT_TERM_BACKEND=memory
NS_LONG_TERM_BACKEND=data/long_term_memory.db
NS_VECTOR_BACKEND=data/vector_memory.db
NS_MAX_FLOW_CONCURRENCY=4
NS_LIT_BINARY_PATH=LIT/lit.windows_x86_64.exe
NS_LIT_MODEL_PATH=LIT/gemma-4-E2B-it.litertlm
NS_LIT_BACKEND=cpu
NS_LIT_TIMEOUT_S=240
NS_LIT_PREVIEW_TIMEOUT_S=75
NS_HANDLER_CERTIFICATE_SECRET=nova-synesis-development-root
NS_HANDLER_CERTIFICATE_ISSUER=NOVA-SYNESIS Root CA
NS_HANDLER_CERTIFICATE_TTL_HOURS=8760
NS_SECURITY_ENABLED=true
NS_SECURITY_AUTO_ISSUE_BUILTIN_HANDLER_CERTIFICATES=true
NS_SECURITY_REQUIRE_TRUSTED_HANDLERS=true
NS_SECURITY_ALLOW_MANUAL_APPROVAL_FOR_UNTRUSTED_HANDLERS=true
NS_SECURITY_MAX_NODES=40
NS_SECURITY_MAX_EDGES=160
NS_SECURITY_MAX_TOTAL_ATTEMPTS=120
NS_SECURITY_MAX_EXPRESSION_LENGTH=512
NS_SECURITY_MAX_EXPRESSION_NODES=64
NS_SECURITY_ALLOW_LOOPBACK_HOSTS=true
NS_SECURITY_HTTP_ALLOWED_HOSTS=127.0.0.1,localhost
NS_SECURITY_SEND_PROTOCOLS=MESSAGE_QUEUE
NS_SECURITY_BLOCKED_HANDLER_KEYWORDS=exploit,phish,credential,scan,bruteforce,exfil,social
NS_SECURITY_BLOCKED_CAPABILITY_KEYWORDS=exploit,phish,credential,scan,bruteforce,exfil,social
NS_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
